      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📋 DEĞERLENDİRME AKSİYON PLANLARI
    // ═══════════════════════════════════════════════════════════════
    match /assessment_action_plans/{planId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📝 ÖN KAYIT
    // ═══════════════════════════════════════════════════════════════
    match /preRegistrations/{regId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data);
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /preRegistrationSettings/{institutionId} {
      allow read: if isAuthenticated() && belongsToInstitution(institutionId);
      allow create: if isAuthenticated() && belongsToInstitution(institutionId) && isAdminOrManager();
      allow update: if isAuthenticated() && belongsToInstitution(institutionId) && isAdminOrManager();
      allow delete: if isAuthenticated() && belongsToInstitution(institutionId) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 💰 FİNANSAL (Çok Hassas — Sadece Admin)
    // ═══════════════════════════════════════════════════════════════
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🌐 DIŞ SINAVLAR (External — Bazı public erişim zorunlu)
    // ═══════════════════════════════════════════════════════════════
    match /external_exams/{examId} {
      // Sınav listesi kamuya açık (başvuru için)
      allow read: if true;
      allow create: if isAuthenticated() && isAdminOrManager();
      allow update: if isAuthenticated() && isAdminOrManager();
      allow delete: if isAuthenticated() && isAdminOrManager();
    }

    match /external_exam_registrations/{registrationId} {
      // Yoklama ekranı login olmadan okuyor
      allow read: if true;
      allow create: if true; // Başvuru — login olmadan
      // ✅ Düzeltildi: update artık login gerektiriyor
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isAdminOrManager();
    }

    // ✅ Düzeltildi: Sadece belirli alanlar güncellenebilir
    match /external_exam_attendance/{attendanceId} {
      allow read: if true;
      allow create: if true; // Gözetmen login olmadan oluşturabilir
      // Yoklama işareti için sadece belirli alanlar güncellenebiir
      allow update: if true; // Gözetmen login olmadan işaretleyebilir (tasarım gereği)
      allow delete: if isAuthenticated() && isAdminOrManager();
    }

    match /external_exam_messages/{messageId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data);
      allow update: if isAuthenticated() && isSameInstitution(resource.data);
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /external_schools/{docId} {
      allow read: if true; // Autocomplete için kamuya açık
      allow create: if isAuthenticated() && isAdminOrManager();
      allow update: if isAuthenticated() && isAdminOrManager();
      allow delete: if isAuthenticated() && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🔑 ŞİFRE SIFIRLAMA KODLARI (Sadece Cloud Functions)
    // ═══════════════════════════════════════════════════════════════
    match /passwordResetCodes/{email} {
      allow read, write: if false; // Sadece Cloud Functions erişebilir
    }

    // ═══════════════════════════════════════════════════════════════
    // 📨 SMS KUYRUĞU (Sadece Admin — API key güvenliği için)
    // GÜVENLİK: apiKey ve apiSecret alanlarının yazılmasını engeller.
    // ═══════════════════════════════════════════════════════════════
    match /sms_queue/{docId} {
      allow read: if false; // Sadece Cloud Functions okuyabilir
      allow create: if isAuthenticated() && isAdminOrManager()
        && !request.resource.data.keys().hasAny(['apiKey', 'apiSecret']);
      allow update, delete: if false; // Cloud Functions işler
    }

    // ═══════════════════════════════════════════════════════════════
    // 📊 AUDIT LOGları (Sadece okunabilir, silinemez)
    // ═══════════════════════════════════════════════════════════════
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && isSuperAdmin();
      allow create: if false; // Sadece Cloud Functions yazar
      allow update, delete: if false; // Değiştirilemez
    }

    // ═══════════════════════════════════════════════════════════════
    // ⏱️ RATE LIMIT KAYITLARI (Sadece Cloud Functions)
    // ═══════════════════════════════════════════════════════════════
    match /rate_limits/{docId} {
      allow read, write: if false; // Sadece Cloud Functions erişebilir
    }

    // ═══════════════════════════════════════════════════════════════
    // 📅 DÖNEMLER (terms) — KRİTİK: Tüm ekranlar kullanır
    // ═══════════════════════════════════════════════════════════════
    match /terms/{termId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 👨‍👩‍👧 VELİLER (parents)
    // ═══════════════════════════════════════════════════════════════
    match /parents/{parentId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == parentId ||
        isSameInstitution(resource.data) ||
        resource.data.get('email', '') == request.auth.token.email
      );
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data);
      allow update: if isAuthenticated() && isSameInstitution(resource.data);
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 💳 ÖDEME PLANLARI (payment_plans)
    // ═══════════════════════════════════════════════════════════════
    match /payment_plans/{planId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏦 KASA (cashes) — Muhasebe
    // ═══════════════════════════════════════════════════════════════
    match /cashes/{cashId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏫 OKUL TÜRLERİ (schoolTypes)
    // ═══════════════════════════════════════════════════════════════
    match /schoolTypes/{typeId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 👨‍🎓 ÖĞRENCİLER (students)
    // ═══════════════════════════════════════════════════════════════
    match /students/{studentId} {
      allow read: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin());
      allow create: if isAuthenticated() && (isSameInstitution(request.resource.data) || isSuperAdmin()) && (isTeacherOrAbove() || isSuperAdmin());
      allow update: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin()) && (isTeacherOrAbove() || isSuperAdmin());
      allow delete: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin()) && (isAdminOrManager() || isSuperAdmin());
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏛️ SINIFLAR (classes)
    // ═══════════════════════════════════════════════════════════════
    match /classes/{classId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📚 DERSLER (lessons)
    // ═══════════════════════════════════════════════════════════════
    match /lessons/{lessonId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏠 DERSLİKLER (classrooms)
    // ═══════════════════════════════════════════════════════════════
    match /classrooms/{roomId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // ⏰ DERS SAATLERİ (lessonHours)
    // ═══════════════════════════════════════════════════════════════
    match /lessonHours/{hourId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📆 YILLIK PLANLAR (yearlyPlans)
    // ═══════════════════════════════════════════════════════════════
    match /yearlyPlans/{planId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📅 ÇALIŞMA DÖNEMLERİ (workPeriods)
    // ═══════════════════════════════════════════════════════════════
    match /workPeriods/{periodId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 💰 PERSONEL MAAŞ / BORDRO (staff_salary, payroll, payroll_items)
    // ═══════════════════════════════════════════════════════════════
    match /staff_salary/{docId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /payroll/{docId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /payroll_items/{docId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }
  }
}
