rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // YARDIMCI FONKSİYONLAR
    // ═══════════════════════════════════════════════════════════════

    // Kullanıcının giriş yapmış olup olmadığını kontrol eder
    function isAuthenticated() {
      return request.auth != null;
    }

    // Kullanıcının Firestore belgesini döndürür
    // Not: Belge yoksa data: {} döner (güvenli default)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Kullanıcının kurum ID'sini döndürür
    function myInstitutionId() {
      return getUserData().get('institutionId', '__NONE__');
    }

    // Kullanıcının rolünü döndürür
    function myRole() {
      return getUserData().get('role', '__NONE__');
    }

    // Bir resourceData'nın aynı kuruma ait olup olmadığını kontrol eder
    function isSameInstitution(resourceData) {
      return myInstitutionId().lower() == resourceData.get('institutionId', '__DIFFERENT__').lower();
    }

    // Kullanıcının belirli bir institution'a ait olup olmadığını kontrol eder
    function belongsToInstitution(institutionId) {
      return myInstitutionId().lower() == institutionId.lower();
    }

    // Kullanıcının belirli bir okula (school) ait olup olmadığını kontrol eder
    // Okullarda institutionId = schoolId varsayımı
    function belongsToSchool(schoolId) {
      return myInstitutionId() == schoolId;
    }

    // Admin veya Müdür mü? (En yetkili rol grubu)
    function isAdminOrManager() {
      return myRole() in ['admin', 'manager', 'genel_mudur', 'mudur'];
    }

    // Yönetim (Müdür yardımcısı dahil)
    function isManagement() {
      return myRole() in ['admin', 'manager', 'genel_mudur', 'mudur', 'mudur_yardimcisi'];
    }

    // Öğretmen veya üstü
    function isTeacherOrAbove() {
      return myRole() in ['admin', 'manager', 'genel_mudur', 'mudur', 'mudur_yardimcisi', 'ogretmen', 'rehber_ogretmen'];
    }

    // Sistem genelinde süper admin (kurumlar arası erişim)
    function isSuperAdmin() {
      return request.auth.token.email.lower() == 'superadmin@edukn.com' || myRole() == 'super_admin';
    }

    // Aktif çalışma dönemi kontrolü
    function isActiveWorkPeriod(periodId, institutionId, schoolTypeId) {
      return periodId != null
        && exists(/databases/$(database)/documents/workPeriods/$(periodId))
        && get(/databases/$(database)/documents/workPeriods/$(periodId)).data.isActive == true
        && get(/databases/$(database)/documents/workPeriods/$(periodId)).data.institutionId == institutionId
        && get(/databases/$(database)/documents/workPeriods/$(periodId)).data.schoolTypeId == schoolTypeId;
    }

    // ═══════════════════════════════════════════════════════════════
    // DEFAULT DENY — Hiçbir explicit match yoksa erişim kapalı
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // 👤 KULLANICILAR — KRİTİK: getUserData() buraya bağlı
    // ÖNEMLİ: Kendi dokümanını okuyabilmek login akışı için şarttır.
    // Bu kural olmadan getUserData() çalışmaz → tüm sistem kilitlenir!
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      // ─────────────────────────────────────────────────────────────
      // READ — Aşağıdaki koşullardan biri yeterlı:
      //   1) Kendi dokümanı (UID eşleşmesi) — login akışı için zorunlu
      //   2) E-posta eşleşmesi — .where('email',...) sorgusu için zorunlu
      //      (UserPermissionService login sırasında kurumId bilinmeden önce
      //       email ile sorgular, bu yüzden isSameInstitution beklenemez)
      //   3) Aynı kurum üyesi — diğer kullanıcıları listelemek için
      //   4) Super Admin — tüm erişim
      // ─────────────────────────────────────────────────────────────
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        resource.data.get('email', '') == request.auth.token.email ||
        resource.data.get('email', '') == request.auth.token.email.lower() ||
        isSameInstitution(resource.data) ||
        isSuperAdmin()
      );

      // Kullanıcı kendi profilini güncelleyebilir (rol ve kurum değiştiremez)
      allow update: if isAuthenticated() && request.auth.uid == userId
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('institutionId' in request.resource.data.diff(resource.data).affectedKeys());

      // Admin/Manager: kendi kurumundaki kullanıcıları yönetebilir
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();

      // Kullanıcı oluşturma: Cloud Functions veya admin
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminOrManager() && isSameInstitution(request.resource.data))
      );

      // Silme: sadece super_admin veya kendi kurumunun admini
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdminOrManager() && isSameInstitution(resource.data))
      );
    }

    // ═══════════════════════════════════════════════════════════════
    // 🔔 BİLDİRİMLER
    // ═══════════════════════════════════════════════════════════════
    match /notifications/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      match /items/{notificationId} {
        allow read, update: if isAuthenticated() && request.auth.uid == userId;
        allow create, delete: if false; // Sadece Cloud Functions yazabilir
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏫 OKULLAR
    // Düzeltildi: Herkese açık değil, kurum üyeliği gerekiyor
    // ═══════════════════════════════════════════════════════════════
    match /schools/{schoolId} {
      // Hem doğrudan ID ile okuma hem de .where() koleksiyon sorguları için
      // belongsToSchool(schoolId) → ID ile erişimde çalışır
      // isSameInstitution(resource.data) → .where() sorgularında çalışır
      allow read: if isAuthenticated() && (
        belongsToSchool(schoolId) ||
        isSameInstitution(resource.data) ||
        isSuperAdmin()
      );
      allow create: if isAuthenticated() && isSuperAdmin();
      allow update: if isAuthenticated() && (
        (belongsToSchool(schoolId) && isAdminOrManager()) ||
        isSuperAdmin()
      );
      allow delete: if isAuthenticated() && isSuperAdmin();

      match /announcements/{announcementId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /announcementGroups/{groupId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /mealPeriods/{periodId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
        match /menus/{menuId} {
          allow read: if isAuthenticated() && belongsToSchool(schoolId);
          allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
          allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
          allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
        }
      }

      match /vehicles/{vehicleId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /healthVisits/{visitId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /libraryBooks/{bookId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /bookLendings/{lendingId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId);
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isTeacherOrAbove();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /cleaningStaff/{staffId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /cleaningAreas/{areaId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }

      match /cleaningLeaves/{leaveId} {
        allow read: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow create: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow update: if isAuthenticated() && belongsToSchool(schoolId) && isManagement();
        allow delete: if isAuthenticated() && belongsToSchool(schoolId) && isAdminOrManager();
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // 👤 ÖĞRENCİLER
    // ═══════════════════════════════════════════════════════════════
    match /students/{studentId} {
      allow read: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin());
      allow create: if isAuthenticated() && (isSameInstitution(request.resource.data) || isSuperAdmin()) && (isTeacherOrAbove() || isSuperAdmin());
      allow update: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin()) && (isTeacherOrAbove() || isSuperAdmin());
      allow delete: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin()) && (isAdminOrManager() || isSuperAdmin());
    }

    // ═══════════════════════════════════════════════════════════════
    // 👥 KULLANICILAR
    // Düzeltildi: Herkes herkes profileni değiştiremez
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Kendi profilini VEYA aynı kurumda admin/manager okuyabilir
      allow get: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSameInstitution(resource.data) ||
        isSuperAdmin()
      );
      // Liste sadece aynı kurum veya süper admin
      allow list: if isAuthenticated() && (isSameInstitution(resource.data) || isSuperAdmin());

      // Hesap oluşturma: Cloud Functions veya kendi okulunun admini/managerı VEYA super_admin
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (isSameInstitution(request.resource.data) && isAdminOrManager())
      );

      // Güncelleme: Kendi profili VEYA aynı kurumda admin/manager
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        (isSameInstitution(resource.data) && isAdminOrManager()) ||
        isSuperAdmin()
      );

      // Silme: Sadece kurum admini veya süper admin
      allow delete: if isAuthenticated() && (
        (isSameInstitution(resource.data) && isAdminOrManager()) ||
        isSuperAdmin()
      );

      // 📝 Kişisel Notlar — sadece kendi kendine
      match /personal_notes/{noteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // 📅 ÇALIŞMA DÖNEMLERİ
    // ═══════════════════════════════════════════════════════════════
    match /workPeriods/{periodId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏷️ OKUL TİPLERİ (Referans veri — global, sadece süper admin yazabilir)
    // ═══════════════════════════════════════════════════════════════
    match /school_types/{typeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    match /schoolTypes/{typeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📊 DENEME SINAVLARI
    // ═══════════════════════════════════════════════════════════════
    match /trial_exams/{examId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();

      match /questions_pool/{questionId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isTeacherOrAbove();
        allow delete: if isAuthenticated() && isAdminOrManager();
      }
    }

    match /{path=**}/questions_pool/{questionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📢 DUYURULAR (Global)
    // ═══════════════════════════════════════════════════════════════
    match /announcements/{announcementId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isManagement();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📋 DEVAMSIZLIK
    // ═══════════════════════════════════════════════════════════════
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /lessonAttendance/{docId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /parentWeeklyUpdates/{docId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📝 NOTLAR
    // ═══════════════════════════════════════════════════════════════
    match /grades/{gradeId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /class_exams/{examId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /optical_forms/{formId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🏛️ SINIFLAR
    // ═══════════════════════════════════════════════════════════════
    match /classes/{classId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isManagement();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /classTypes/{typeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isAdminOrManager();
    }

    match /classrooms/{classroomId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isManagement();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 🛡️ NÖBETLEr
    // ═══════════════════════════════════════════════════════════════
    match /dutyHistory/{historyId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyLocations/{locationId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyRules/{ruleId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyEligibilities/{eligibilityId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /teacherDutyPreferences/{prefId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isTeacherOrAbove();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isTeacherOrAbove();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyMap/{assignmentId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyPrograms/{programId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /dutyScheduleItems/{itemId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📆 DÖNEM / ŞUBE
    // ═══════════════════════════════════════════════════════════════
    match /terms/{termId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isAdminOrManager();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isAdminOrManager();
    }

    // ═══════════════════════════════════════════════════════════════
    // 📚 DERSLER / ATAMALAR
    // ═══════════════════════════════════════════════════════════════
    match /lessons/{lessonId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isManagement();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /lessonAssignments/{assignmentId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
      allow update: if isAuthenticated() && isSameInstitution(resource.data) && isManagement();
      allow delete: if isAuthenticated() && isSameInstitution(resource.data) && isAdminOrManager();
    }

    match /classroomLessons/{assignmentId} {
      allow read: if isAuthenticated() && isSameInstitution(resource.data);
      allow create: if isAuthenticated() && isSameInstitution(request.resource.data) && isManagement();
