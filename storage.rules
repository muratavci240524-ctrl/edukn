rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read/write access to the 'social_posts' folder for authenticated users
    match /social_posts/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Default deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
